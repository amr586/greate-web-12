modules = ["nodejs-20", "web", "bash"]
[agent]
expertMode = true
integrations = ["javascript_openai_ai_integrations:2.0.0"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start backend"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx vite --host 0.0.0.0 --port 5000"
waitForPort = 5000

[[workflows.workflow]]
name = "Start backend"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx tsx backend/index.ts"
waitForPort = 3001

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5003
externalPort = 4200

[[ports]]
localPort = 5004
externalPort = 5173

[[ports]]
localPort = 5005
externalPort = 6000

[[ports]]
localPort = 5006
externalPort = 6800

[[ports]]
localPort = 5007
externalPort = 8081

[[ports]]
localPort = 5008
externalPort = 9000

[[ports]]
localPort = 5009
externalPort = 8000

[[ports]]
localPort = 5010
externalPort = 8008

[[ports]]
localPort = 5011
externalPort = 8080

[[ports]]
localPort = 5012
externalPort = 8099

[deployment]
deploymentTarget = "autoscale"
build = ["pnpm", "run", "build"]
run = ["bash", "-c", "NODE_ENV=production npx tsx server/index.ts"]

[userenv]

[userenv.production]
NODE_ENV = "production"

[userenv.development]
