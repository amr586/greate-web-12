# ==========================================
# Great Society - Environment Variables
# ==========================================
# Copy this file to .env and fill in values

# ------------------------------------------
# FRONTEND API URL (For Vercel)
# ------------------------------------------
# When frontend is deployed to Vercel and backend to Render:
# Set to your Render URL: https://great-society-api.onrender.com/api
VITE_API_URL=https://great-society-api.onrender.com/api

# ------------------------------------------
# DATABASE (Required for Backend)
# ------------------------------------------
# Render will auto-set this after you connect the database
# Format: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ------------------------------------------
# JWT SECRET (Required)
# ------------------------------------------
# Used to sign login tokens - keep this secret!
# Use the value below or generate your own with:
# node -e "require('crypto').randomBytes(64).toString('hex')"
JWT_SECRET=bb0f2dafd91237a0a36ca7fe58931b0b242812cbba85ba80035ed387ac791617f181696986adb03dbeb487a35d7c7d8f6d630c12a8da2d53981b882104cc5aa2

# ------------------------------------------
# OPENAI (Optional - for AI assistant feature)
# ------------------------------------------
# Get from: platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# ------------------------------------------
# SERVER CONFIG
# ------------------------------------------
PORT=3001
NODE_ENV=production

# ------------------------------------------
# EMAIL / OTP (Optional - for email verification)
# ------------------------------------------
# Gmail: enable "App Passwords" in Google Account settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
