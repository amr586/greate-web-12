# Great Society - Hostinger SPA Configuration
# Serve index.html for all non-file, non-API requests

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
</IfModule>

# If request is for a real file, serve it
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# If request is for a real directory, serve it  
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# API requests - this shouldn't match since frontend is separate
RewriteCond %{REQUEST_URI} ^/api
RewriteRule ^ - [L]

# Serve index.html for all other routes (SPA fallback)
RewriteRule ^ /index.html [L]