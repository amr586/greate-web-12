{
  "version": 2,
  "builds": [
    {
      "src": "dist/**",
      "use": "@vercel/static"
    },
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.ts"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/dist/assets/$1"
    },
    {
      "src": "/favicon.png",
      "dest": "/dist/favicon.png"
    },
    {
      "src": "/logo_gs.png",
      "dest": "/dist/logo_gs.png"
    },
    {
      "src": "/prop1_exterior.png",
      "dest": "/dist/prop1_exterior.png"
    },
    {
      "src": "/prop1_floorplan.png",
      "dest": "/dist/prop1_floorplan.png"
    },
    {
      "src": "/prop1_interior.png",
      "dest": "/dist/prop1_interior.png"
    },
    {
      "src": "/prop2_exterior.png",
      "dest": "/dist/prop2_exterior.png"
    },
    {
      "src": "/prop2_floorplan.png",
      "dest": "/dist/prop2_floorplan.png"
    },
    {
      "src": "/prop2_interior.png",
      "dest": "/dist/prop2_interior.png"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/index.html"
    },
    {
      "src": "/",
      "dest": "/dist/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 5 * * *"
    }
  ]
}
