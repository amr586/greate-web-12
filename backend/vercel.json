{
  "version": 2,
  "builds": [
    {
      "src": "server.ts",
      "use": "@vercel/node"
    }
  ],
  "install": {
    "packageManager": "npm"
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.ts"
    }
  ],
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 5 * * *"
    }
  ]
}
